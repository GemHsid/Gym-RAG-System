/* pages/ai/ai.wxss */
page {
  height: 100vh;
  display: flex;
  flex-direction: column;
  background-color: var(--bg);
}

.container {
  height: 100%;
  display: flex;
  flex-direction: column;
  padding: 0;
  justify-content: flex-start;
}

.chat-state {
  margin: 20rpx 30rpx 0;
  padding: 16rpx 20rpx;
  border-radius: 12rpx;
  background: #FDF6F0;
  color: #8B3A3A;
  font-size: 24rpx;
}

.rag-debug-bar {
  margin: 20rpx 30rpx 0;
  padding: 18rpx 20rpx;
  border-radius: 16rpx;
  background: #fff;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.05);
}

.rag-debug-line {
  display: block;
  color: #6B4F46;
  font-size: 22rpx;
  line-height: 1.6;
  word-break: break-all;
}

/* 顶部栏 */
.ai-header {
  background-color: var(--primary);
  color: #fff;
  padding: 20rpx 30rpx;
  display: flex;
  justify-content: space-between;
  align-items: center;
  box-shadow: 0 4rpx 10rpx rgba(0,0,0,0.1);
  z-index: 10;
}

.ai-title {
  font-size: 32rpx;
  font-weight: bold;
}

.ai-actions {
  display: flex;
  gap: 20rpx;
}

.icon-btn {
  width: 40rpx;
  height: 40rpx;
  border: 2rpx solid rgba(255,255,255,0.6);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 24rpx;
}

/* 聊天列表 */
.chat-list {
  flex: 1;
  width: 100%;
  padding: 30rpx;
  box-sizing: border-box;
  background: var(--bg);
}

.message-item {
  display: flex;
  margin-bottom: 40rpx;
  align-items: flex-start;
}

.ai-message {
  flex-direction: row;
}

.user-message {
  flex-direction: row-reverse;
}

/* 头像 */
.avatar {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 40rpx;
  flex-shrink: 0;
  box-shadow: 0 4rpx 10rpx rgba(0,0,0,0.1);
  border: 4rpx solid #fff;
}

.ai-message .avatar {
  background-color: #D7B19D;
  margin-right: 20rpx;
}

.user-message .avatar {
  background-color: var(--primary);
  margin-left: 20rpx;
}

/* 气泡 */
.bubble {
  max-width: 70%;
  padding: 24rpx 32rpx;
  border-radius: 24rpx;
  font-size: 28rpx;
  line-height: 1.6;
  position: relative;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.05);
}

.ai-message .bubble {
  background-color: #fff;
  color: #333;
  border-top-left-radius: 4rpx;
}

.user-message .bubble {
  background-color: var(--primary);
  color: #fff;
  border-top-right-radius: 4rpx;
}

.message-meta {
  margin-top: 20rpx;
  padding-top: 18rpx;
  border-top: 1rpx solid rgba(0,0,0,0.08);
}

.message-meta-title {
  display: block;
  margin-bottom: 10rpx;
  color: #8B5E3C;
  font-size: 22rpx;
  font-weight: bold;
}

.message-meta-text {
  display: block;
  color: #666;
  font-size: 22rpx;
  line-height: 1.6;
}

.message-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}

.message-tag {
  display: inline-block;
  padding: 8rpx 18rpx;
  border-radius: 999rpx;
  background: #F5EFE9;
  color: #6B4F46;
  font-size: 20rpx;
}

.message-endpoint {
  display: block;
  margin-top: 18rpx;
  color: #999;
  font-size: 20rpx;
  word-break: break-all;
}

/* 底部操作区 */
.footer {
  position: relative;
  left: 0;
  width: 100%;
  background-color: var(--bg);
  box-shadow: 0 -2rpx 10rpx rgba(0,0,0,0.05);
  padding-bottom: env(safe-area-inset-bottom);
}

/* 快捷标签 */
.quick-tags {
  white-space: nowrap;
  height: 70rpx;
  padding: 20rpx 30rpx 0 30rpx; /* 减少间距 */
  display: flex;
}

.tag {
  display: inline-block;
  background-color: #E8D5C8;
  color: #5D4037;
  font-size: 24rpx;
  padding: 10rpx 24rpx;
  border-radius: 30rpx;
  margin-right: 20rpx;
}

/* 输入区域 */
.input-area {
  display: flex;
  align-items: center;
  padding: 20rpx 30rpx;
  background: #fff;
  padding-bottom: 20rpx;
}

.chat-textarea {
  flex: 2; /* 占 2/3 */
  background-color: #fff;
  height: 88rpx;
  border-radius: 44rpx;
  padding: 22rpx 36rpx;
  font-size: 30rpx;
  margin-right: 20rpx;
  border: 1px solid #E0E0E0;
  box-shadow: inset 0 2rpx 4rpx rgba(0,0,0,0.05);
  box-sizing: border-box;
  line-height: 1.3;
  overflow-y: hidden;
}

.input-placeholder {
  color: #BDBDBD;
}

.send-btn {
  flex: 1; /* 占 1/3 */
  height: 88rpx;
  line-height: 88rpx;
  background-color: var(--primary); /* 同主题色 */
  color: #fff;
  font-size: 30rpx;
  border-radius: 44rpx;
  padding: 0;
  margin: 0;
  font-weight: bold;
  transition: all 0.2s;
  box-shadow: 0 4rpx 12rpx rgba(122, 26, 26, 0.3);
}

.send-btn[disabled] {
  background-color: #E8D5C8; /* 禁用状态用浅色主题 */
  color: #fff;
  box-shadow: none;
}

/* Loading 动画 */
.loading {
  display: flex;
  align-items: center;
  min-height: 40rpx;
}

.dot {
  width: 10rpx;
  height: 10rpx;
  background-color: #999;
  border-radius: 50%;
  margin: 0 6rpx;
  animation: bounce 1.4s infinite ease-in-out both;
}

.dot:nth-child(1) { animation-delay: -0.32s; }
.dot:nth-child(2) { animation-delay: -0.16s; }

@keyframes bounce {
  0%, 80%, 100% { transform: scale(0); }
  40% { transform: scale(1); }
}
