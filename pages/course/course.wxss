/* pages/course/course.wxss */
.container {
  padding: 0;
  background-color: var(--bg);
  min-height: 100vh;
}

.page-state {
  margin: 20rpx 30rpx 0;
  padding: 16rpx 20rpx;
  border-radius: 12rpx;
  background: #FDF6F0;
  color: #8B3A3A;
  font-size: 24rpx;
}

.empty-text {
  text-align: center;
  color: #8D6E63;
  font-size: 24rpx;
  padding: 40rpx 0;
}

.header-bg {
  height: 200rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  position: relative;
}

.gym-name-main {
  font-size: 30rpx;
  font-weight: bold;
  color: #333;
  z-index: 2;
}

.logo-2025 {
  position: absolute;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  font-size: 160rpx;
  font-weight: 900;
  color: rgba(139, 58, 58, 0.1); /* 主色调淡化作为背景 */
  font-style: italic;
  z-index: 1;
}

/* 日历条 */
.calendar-strip {
  display: flex;
  justify-content: space-around;
  padding: 0 20rpx;
  margin-bottom: 40rpx;
}

.calendar-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  width: 90rpx;
}

.date-num {
  font-size: 36rpx;
  width: 70rpx;
  height: 70rpx;
  line-height: 70rpx;
  text-align: center;
  border-radius: 50%;
  margin-bottom: 12rpx;
  color: #333;
}

.calendar-item.active .date-num {
  background-color: var(--primary);
  color: #fff;
}

.date-week {
  font-size: 24rpx;
  color: #666;
}

/* 筛选器 */
.filter-bar {
  text-align: center;
  margin-bottom: 40rpx;
  font-size: 30rpx;
  font-weight: bold;
  color: #333;
}

/* 列表容器 */
.course-list {
  padding: 0 30rpx;
  height: calc(100vh - 450rpx);
}

.coach-section {
  background: #FDF6F0; 
  border-radius: 30rpx;
  margin-bottom: 30rpx;
  overflow: hidden;
  box-shadow: 0 4rpx 16rpx rgba(0,0,0,0.05);
  border: 1rpx solid rgba(139, 58, 58, 0.1);
}

.coach-card {
  display: flex;
  align-items: center;
  padding: 30rpx;
}

.coach-avatar-wrapper {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  overflow: hidden;
  margin-right: 24rpx;
  border: 4rpx solid #fff;
}

.coach-avatar {
  width: 100%;
  height: 100%;
}

.coach-info {
  flex: 1;
}

.coach-name {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
}

.coach-title {
  font-size: 24rpx;
  font-weight: normal;
  color: #666;
}

.action-btn {
  background-color: var(--primary);
  color: #fff;
  font-size: 26rpx;
  padding: 0 40rpx;
  height: 64rpx;
  line-height: 64rpx;
  border-radius: 32rpx;
  margin: 0;
  font-weight: bold;
}

.action-btn.grey {
  background-color: #666;
}

/* 子课程列表 */
.sub-course-list {
  padding: 0 30rpx 30rpx 30rpx;
  border-top: 1rpx solid rgba(0,0,0,0.05);
}

.sub-course-item {
  display: flex;
  align-items: center;
  padding: 20rpx 0;
}

.sub-course-avatar {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  margin-right: 20rpx;
}

.sub-course-name {
  flex: 1;
  font-size: 28rpx;
  color: #444;
}

/* 筛选侧边栏 */
.filter-modal {
  position: fixed;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  background: rgba(0,0,0,0.6);
  z-index: 100;
  visibility: hidden;
  opacity: 0;
  transition: all 0.3s;
}

.filter-modal.show {
  visibility: visible;
  opacity: 1;
}

.filter-content {
  position: absolute;
  top: 0;
  left: 0;
  width: 60%;
  height: 100%;
  background: var(--bg);
  display: flex;
  flex-direction: column;
  transform: translateX(-100%);
  transition: all 0.3s;
}

.filter-modal.show .filter-content {
  transform: translateX(0);
}

.filter-header {
  padding: 60rpx 30rpx 40rpx;
  font-size: 28rpx;
  color: #999;
}

.filter-options {
  flex: 1;
  padding: 0 30rpx;
}

.filter-opt {
  height: 80rpx;
  line-height: 80rpx;
  background: #fff;
  border-radius: 12rpx;
  margin-bottom: 24rpx;
  text-align: center;
  font-size: 28rpx;
  color: #333;
}

.filter-opt.active {
  background-color: var(--primary);
  color: #fff;
}

.filter-footer {
  display: flex;
  height: 100rpx;
}

.footer-btn {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 30rpx;
}

.footer-btn.clear {
  background: #fff;
  color: #333;
}

.footer-btn.confirm {
  background: var(--primary);
  color: #fff;
}
