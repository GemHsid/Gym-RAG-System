/* pages/course/detail.wxss */
.container {
  padding-bottom: 120rpx;
  background-color: #fff;
}

.detail-header {
  position: relative;
  height: 400rpx;
  background: var(--primary);
}

.cover-img {
  width: 100%;
  height: 100%;
  object-fit: cover;
}

.cover-placeholder {
  width: 100%;
  height: 100%;
  display: flex;
  align-items: center;
  justify-content: center;
  background: linear-gradient(135deg, #6f2e2e 0%, #3e2723 100%);
}

.cover-placeholder-text {
  color: #fff;
  font-size: 34rpx;
  font-weight: 600;
}

.header-overlay {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: linear-gradient(to bottom, rgba(0,0,0,0.5) 0%, rgba(0,0,0,0) 50%, rgba(0,0,0,0.6) 100%);
}

.back-btn {
  position: absolute;
  top: 60rpx;
  left: 30rpx;
  width: 60rpx;
  height: 60rpx;
  background: rgba(255,255,255,0.2);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #fff;
  z-index: 10;
}

.coach-name-top {
  position: absolute;
  bottom: 30rpx;
  left: 30rpx;
  color: #fff;
  font-size: 28rpx;
  font-weight: 500;
  z-index: 10;
  text-shadow: 0 2rpx 4rpx rgba(0,0,0,0.3);
}

.course-info-section {
  padding: 40rpx 30rpx;
  background: #fff;
  border-radius: 30rpx 30rpx 0 0;
  margin-top: -30rpx;
  position: relative;
  z-index: 11;
}

.title-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 30rpx;
  padding-bottom: 20rpx;
  border-bottom: 1rpx solid #eee;
}

.course-title {
  font-size: 44rpx;
  font-weight: 800;
  color: #333;
}

.limit-tag {
  font-size: 24rpx;
  color: var(--primary);
  background: rgba(140, 28, 28, 0.1);
  padding: 6rpx 16rpx;
  border-radius: 20rpx;
  font-weight: bold;
}

.info-list {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

.info-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  font-size: 28rpx;
}

.info-label {
  color: #888;
}

.info-value {
  color: #333;
  font-weight: 500;
}

.limit-highlight {
  color: var(--primary);
  font-size: 32rpx;
  font-weight: bold;
}

.points-tag {
  display: inline-block;
  background: #FFF0F0;
  color: var(--primary);
  font-size: 22rpx;
  padding: 4rpx 16rpx;
  border-radius: 20rpx;
}

.selection-title {
  padding: 0 30rpx;
  font-size: 34rpx;
  font-weight: bold;
  margin-bottom: 30rpx;
}

.date-scroll {
  white-space: nowrap;
  padding: 0 30rpx;
  margin-bottom: 40rpx;
}

.date-item {
  display: inline-flex;
  flex-direction: column;
  align-items: center;
  width: 100rpx;
  margin-right: 20rpx;
}

.date-item .date-num {
  width: 70rpx;
  height: 70rpx;
  line-height: 70rpx;
  text-align: center;
  font-size: 34rpx;
  color: #333;
  border-radius: 50%;
  margin-bottom: 10rpx;
}

.date-item.active .date-num {
  background: var(--primary);
  color: #fff;
}

.date-item .date-week {
  font-size: 24rpx;
  color: #666;
}

.time-grid-container {
  padding: 0 30rpx;
  background: #f9f9f9;
}

.grid-hint {
  font-size: 22rpx;
  color: #bbb;
  padding: 30rpx 0;
}

.time-grid {
  display: grid;
  grid-template-columns: repeat(5, 1fr);
  gap: 15rpx;
  padding-bottom: 40rpx;
}

.time-slot {
  height: 100rpx;
  background: #fff;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  border-radius: 8rpx;
  position: relative;
}

.time-slot.passed {
  background: #eee;
  color: #ccc;
}

.time-slot.booked {
  background: #F3E5F5;
  color: #8E24AA;
}

.time-slot.selected {
  background: var(--primary);
  color: #fff;
}

.time-text {
  font-size: 26rpx;
}

.status-text {
  position: absolute;
  bottom: 4rpx;
  right: 8rpx;
  font-size: 18rpx;
}

.footer {
  position: fixed;
  bottom: 0;
  left: 0;
  width: 100%;
  display: flex;
  gap: 20rpx;
  padding: 20rpx 30rpx;
  background: #fff;
  box-sizing: border-box;
  box-shadow: 0 -2rpx 10rpx rgba(0,0,0,0.05);
}

.reserve-btn {
  flex: 1;
  background: #111;
  color: #fff;
  border-radius: 50rpx;
  font-weight: bold;
}

.reserve-btn.disabled {
  background: #d7d7d7;
  color: #ffffff;
}

.buy-card-btn {
  flex: 1;
  background: var(--primary);
  color: #fff;
  border-radius: 50rpx;
  font-weight: bold;
}
