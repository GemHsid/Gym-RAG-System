/* pages/home/home.wxss */
.container {
  padding: 0;
  padding-bottom: 40rpx;
  background-color: var(--bg);
}

.page-state {
  margin: 20rpx 30rpx 0;
  padding: 16rpx 20rpx;
  border-radius: 12rpx;
  background: #FDF6F0;
  color: #8B3A3A;
  font-size: 24rpx;
}

.empty-text {
  text-align: center;
  color: #8D6E63;
  font-size: 24rpx;
  padding: 30rpx 0;
}

/* 顶部 Banner */
.header-section {
  width: 100%;
  height: 480rpx;
  position: relative;
}

.banner-bg {
  width: 100%;
  height: 100%;
}

.banner-placeholder {
  width: 100%;
  height: 100%;
  padding: 0 48rpx;
  box-sizing: border-box;
  display: flex;
  flex-direction: column;
  justify-content: center;
  background: linear-gradient(135deg, #3d2a28 0%, #7b4d46 100%);
  color: #fff;
}

.banner-placeholder-title {
  font-size: 42rpx;
  font-weight: 700;
  margin-bottom: 16rpx;
}

.banner-placeholder-desc {
  font-size: 24rpx;
  opacity: 0.88;
}

.overlay {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  background: linear-gradient(to bottom, rgba(0,0,0,0) 0%, rgba(0,0,0,0.2) 60%, rgba(0,0,0,0.6) 100%);
}

.floating-nav {
  position: absolute;
  bottom: 80rpx;
  width: 100%;
  display: flex;
  justify-content: space-between;
  padding: 0 40rpx;
  box-sizing: border-box;
  z-index: 5;
}

.nav-pill {
  background: rgba(0, 0, 0, 0.4);
  backdrop-filter: blur(10px);
  color: #fff;
  padding: 12rpx 30rpx;
  border-radius: 30rpx;
  font-size: 26rpx;
  font-weight: 500;
  border: 1px solid rgba(255,255,255,0.2);
}

.nav-pill-group {
  display: flex;
  background: rgba(0, 0, 0, 0.4);
  backdrop-filter: blur(10px);
  border-radius: 30rpx;
  overflow: hidden;
  border: 1px solid rgba(255,255,255,0.2);
}

.nav-pill-right {
  padding: 12rpx 24rpx;
  color: #fff;
  font-size: 26rpx;
  border-right: 1px solid rgba(255,255,255,0.2);
}

.nav-pill-right:last-child {
  border-right: none;
}

/* 1. 店面介绍页 */
.gym-info-card {
  background: #FDF6F0;
  margin: -40rpx 30rpx 24rpx 30rpx;
  padding: 30rpx;
  border-radius: var(--border-radius-lg);
  position: relative;
  z-index: 10;
  box-shadow: 0 10rpx 30rpx rgba(0,0,0,0.08);
}

.gym-header {
  display: flex;
  align-items: flex-start;
}

.gym-logo {
  width: 100rpx;
  height: 100rpx;
  background: #fff;
  border-radius: 50%;
  border: 4rpx solid #333;
  overflow: hidden;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 24rpx;
  flex-shrink: 0;
}

.gym-logo text {
  font-size: 24rpx;
  font-weight: bold;
  color: #333;
}

.gym-logo-image {
  width: 100%;
  height: 100%;
  display: block;
}

.gym-details {
  flex: 1;
}

.gym-name-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 12rpx;
}

.gym-name {
  font-size: 32rpx;
  font-weight: 900;
  color: #2D2D2D;
}

.gym-distance {
  font-size: 24rpx;
  color: var(--primary);
  font-weight: bold;
  display: flex;
  align-items: center;
}

.icon-location {
  margin-right: 4rpx;
}

.gym-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}

.tag.filled {
  background: #E0C8BA;
  padding: 4rpx 12rpx;
  border-radius: 8rpx;
  color: #4E342E;
  font-size: 20rpx;
  font-weight: 500;
}

.gym-detail-icon {
  margin-left: 10rpx;
  color: #999;
  font-size: 30rpx;
  padding-top: 6rpx;
}

/* 2. 三大金刚位 */
.quick-actions-grid {
  display: flex;
  justify-content: space-between;
  padding: 0 30rpx;
  gap: 20rpx;
  margin-bottom: 30rpx;
}

.action-card {
  flex: 1;
  height: 180rpx;
  border-radius: 24rpx;
  overflow: hidden;
  position: relative;
  box-shadow: var(--shadow-sm);
  background: linear-gradient(135deg, #8b3a3a 0%, #5f2727 100%);
}

.action-bg {
  width: 100%;
  height: 100%;
  position: absolute;
  top: 0;
  left: 0;
}

.action-overlay {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  background: rgba(0,0,0,0.4);
}

.action-card-guide {
  background: linear-gradient(135deg, #5d4037 0%, #8d6e63 100%);
}

.action-card-equipment {
  background: linear-gradient(135deg, #4e342e 0%, #795548 100%);
}

.action-content {
  position: relative;
  z-index: 2;
  height: 100%;
  display: flex;
  flex-direction: column;
  justify-content: center;
  padding-left: 24rpx;
}

.action-title {
  color: #fff;
  font-size: 32rpx;
  font-weight: bold;
  margin-bottom: 8rpx;
}

.action-desc {
  color: rgba(255,255,255,0.8);
  font-size: 22rpx;
}

.nav-icon {
  position: absolute;
  top: 16rpx;
  right: 16rpx;
  color: #fff;
  font-size: 24rpx;
  background: rgba(0,0,0,0.3);
  width: 40rpx;
  height: 40rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 3;
}

/* 3. 会员卡套餐 */
.membership-section {
  padding: 0 30rpx;
  margin-bottom: 40rpx;
}

.section-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 24rpx;
}

.section-title {
  font-size: 34rpx;
  font-weight: 900;
  color: #2D2D2D;
  border-left: 8rpx solid var(--primary);
  padding-left: 16rpx;
}

.more-link {
  font-size: 26rpx;
  color: #5D4037;
}

.membership-scroll {
  display: flex;
  flex-direction: row;
  height: 400rpx; /* 增加到400rpx，确保按钮不溢出 */
}

.membership-card {
  width: 280rpx;
  height: 100%;
  background: #E8D5C8;
  border-radius: 24rpx;
  margin-right: 20rpx;
  padding: 30rpx 24rpx; /* 恢复适当内边距 */
  box-sizing: border-box;
  display: flex;
  flex-direction: column;
  position: relative;
  flex-shrink: 0;
  box-shadow: var(--shadow-sm);
  justify-content: flex-start; /* 改为从上往下排列 */
  overflow: hidden;
}

.card-tag {
  position: absolute;
  top: 0;
  right: 0;
  background: var(--primary);
  color: #fff;
  font-size: 20rpx;
  padding: 4rpx 12rpx;
  border-bottom-left-radius: 16rpx;
  border-top-right-radius: 24rpx;
}

.card-name {
  font-size: 30rpx;
  font-weight: 800;
  color: #3E2723;
  margin-bottom: 6rpx;
  margin-top: 20rpx; /* 顶部留白 */
}

.card-duration {
  font-size: 22rpx;
  color: #5D4037;
  opacity: 0.8;
  margin-bottom: 20rpx;
}

.card-price-row {
  display: flex;
  align-items: baseline;
  margin-bottom: auto; /* 价格下方自动填充 */
}

.symbol {
  font-size: 24rpx;
  font-weight: bold;
}

.amount {
  font-size: 40rpx;
  font-weight: 900;
  color: #2D2D2D;
  margin-right: 8rpx;
}

.original {
  font-size: 20rpx;
  color: #8D6E63;
  text-decoration: line-through;
}

.buy-btn-sm {
  background: var(--primary);
  color: #fff;
  font-size: 24rpx;
  width: 220rpx; /* 稍微加宽 */
  height: 60rpx; /* 稍微减低，更扁 */
  line-height: 60rpx;
  border-radius: 30rpx;
  text-align: center;
  margin: 20rpx auto 0; /* 居中 */
  font-weight: bold;
}

/* 团购核销卡片 (新版-列表下方) */
.redeem-block {
  margin-top: 24rpx;
  background: #D7B19D;
  border-radius: 16rpx;
  padding: 30rpx;
  display: flex;
  justify-content: center; /* 居中 */
  align-items: center;
  box-shadow: var(--shadow-sm);
  position: relative;
}

.redeem-left {
  display: flex;
  align-items: center;
}

.redeem-title {
  font-size: 30rpx;
  font-weight: bold;
  color: #3E2723;
}

.redeem-arrow {
  position: absolute;
  right: 30rpx;
  color: #5D4037;
  font-weight: bold;
}

/* 4. 健身房实况 */
.live-status-section {
  padding: 0 30rpx;
  margin-bottom: 20rpx;
}

.status-grid {
  display: flex;
  justify-content: space-between;
  background: #FDF6F0;
  border-radius: 24rpx;
  padding: 30rpx;
  box-shadow: var(--shadow-sm);
}

.status-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  flex: 1;
  position: relative;
}

.status-item:not(:last-child)::after {
  content: "";
  position: absolute;
  right: 0;
  top: 10%;
  height: 80%;
  width: 2rpx;
  background: rgba(0,0,0,0.05);
}

.status-icon {
  font-size: 36rpx;
  margin-bottom: 8rpx;
}

.status-val {
  font-size: 28rpx;
  font-weight: bold;
  color: #2D2D2D;
}

.status-label {
  font-size: 20rpx;
  color: #8D6E63;
}

/* 弹窗通用 */
.modal-mask {
  position: fixed;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  background: rgba(0,0,0,0.6);
  z-index: 100;
  display: flex;
  align-items: center;
  justify-content: center;
}

.modal-content {
  background: #fff;
  border-radius: 24rpx;
  overflow: hidden;
}

/* 抢购弹窗特有样式 */
.buy-modal {
  width: 720rpx; /* 最大化宽度 */
  position: relative;
  overflow: visible;
}

.close-icon-circle {
  position: absolute;
  top: -20rpx;
  right: -20rpx;
  width: 60rpx;
  height: 60rpx;
  background: #ccc;
  border-radius: 50%;
  color: #fff;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 40rpx;
  z-index: 10;
  border: 4rpx solid #fff;
}

.buy-header {
  background: linear-gradient(135deg, #8B3A3A 0%, #6F2E2E 100%);
  padding: 40rpx;
  text-align: center;
  position: relative;
  border-top-left-radius: 24rpx;
  border-top-right-radius: 24rpx;
}

.card-name-lg {
  font-size: 36rpx;
  font-weight: bold;
  color: #FFFFFF;
  margin-bottom: 10rpx;
}

.card-validity-lg {
  font-size: 26rpx;
  color: rgba(255,255,255,0.85);
  margin-bottom: 10rpx;
}

.card-price-lg {
  font-size: 32rpx;
  font-weight: bold;
  color: #FFFFFF;
}

.crown-bg {
  position: absolute;
  right: 20rpx;
  bottom: 20rpx;
  width: 100rpx;
  opacity: 0.3;
}

.buy-body {
  padding: 30rpx;
  background: #fff;
  border-bottom-left-radius: 24rpx;
  border-bottom-right-radius: 24rpx;
}

.buy-desc {
  font-size: 24rpx;
  color: #333;
  margin-bottom: 20rpx;
  line-height: 1.4;
}

.buy-input {
  background: #F5F5F5;
  height: 80rpx;
  border-radius: 8rpx;
  padding: 0 20rpx;
  font-size: 28rpx;
  margin-bottom: 20rpx;
}

.redeem-modal {
  width: 620rpx;
  border-radius: 26rpx;
}

.redeem-modal .modal-header {
  padding: 30rpx 90rpx 14rpx 30rpx;
  min-height: 70rpx;
  border-bottom: 1px solid #f2e8e1;
  position: relative;
  display: flex;
  align-items: center;
  justify-content: center;
}

.redeem-modal .close-icon {
  position: absolute;
  right: 18rpx;
  top: 18rpx;
  width: 56rpx;
  height: 56rpx;
  border-radius: 50%;
  background: #fff;
  border: 1px solid #efe4dc;
  color: #8B3A3A;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 36rpx;
}

.redeem-modal .modal-title {
  width: 100%;
  text-align: center;
  line-height: 1.2;
}

.redeem-modal .modal-body {
  padding: 24rpx 30rpx 34rpx;
}

.redeem-subtitle {
  display: block;
  margin-bottom: 18rpx;
  color: #8D6E63;
  font-size: 24rpx;
}

.redeem-input-wrap {
  display: flex;
  align-items: center;
  background: #F9F5F2;
  border: 1px solid #EADFD7;
  border-radius: 14rpx;
  padding: 0 18rpx;
}

.redeem-input-icon {
  font-size: 28rpx;
  margin-right: 10rpx;
}

.redeem-input {
  flex: 1;
  height: 86rpx;
  font-size: 28rpx;
}

.redeem-btn {
  margin-top: 22rpx;
  border-radius: 999rpx;
  background: var(--primary);
  color: #fff;
  font-size: 30rpx;
  font-weight: 600;
}

.redeem-btn::after {
  border: none;
}

.confirm-read-btn {
  background: #BDBDBD;
  color: #fff;
  font-size: 30rpx;
  border-radius: 44rpx;
  margin-bottom: 20rpx;
  transition: all 0.3s;
}

.confirm-read-btn.active {
  background: #8B3A3A; /* 激活后变深红 */
}

/* 抖动动画 */
@keyframes shake {
  0%, 100% { transform: translateX(0); }
  10%, 30%, 50%, 70%, 90% { transform: translateX(-10rpx); }
  20%, 40%, 60%, 80% { transform: translateX(10rpx); }
}

.shake {
  animation: shake 0.5s;
  color: #D32F2F; /* 错误提示色 */
}

.agreement-row {
  display: flex;
  align-items: center;
  font-size: 24rpx;
  color: #999;
}

.agreement-checkbox {
  transform: scale(0.7);
}

.recommend-course-list {
  background: #FDF6F0;
  border-radius: 24rpx;
  padding: 12rpx 18rpx;
  box-shadow: var(--shadow-sm);
}

.recommend-course-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 18rpx 6rpx;
  border-bottom: 1px solid rgba(0, 0, 0, 0.04);
}

.recommend-course-item:last-child {
  border-bottom: none;
}

.recommend-course-main {
  display: flex;
  flex-direction: column;
}

.recommend-course-name {
  font-size: 30rpx;
  font-weight: 700;
  color: #2D2D2D;
  margin-bottom: 12rpx;
}

.recommend-course-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-bottom: 8rpx;
}

.course-tag {
  font-size: 20rpx;
  color: #8B3A3A;
  background: rgba(139, 58, 58, 0.1);
  padding: 4rpx 12rpx;
  border-radius: 8rpx;
}

.recommend-course-meta {
  font-size: 22rpx;
  color: #8D6E63;
  line-height: 1.4;
}

.equipment-thumb {
  width: 100%;
  height: 160rpx;
  margin-top: 18rpx;
  border-radius: 16rpx;
}

.equipment-thumb-empty {
  display: flex;
  align-items: center;
  justify-content: center;
  background: #f4ece7;
  color: #8d6e63;
  font-size: 24rpx;
}
