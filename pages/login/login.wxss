/* pages/login/login.wxss */
.container {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 100rpx 60rpx;
  min-height: 100vh;
  background-color: #FDF6F0;
  box-sizing: border-box;
}

.header {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-bottom: 120rpx;
  margin-top: 80rpx;
}

.logo-shell {
  width: 180rpx;
  height: 180rpx;
  border-radius: 50%;
  overflow: hidden;
  background: #fff;
  border: 6rpx solid rgba(139, 58, 58, 0.12);
  box-shadow: 0 10rpx 24rpx rgba(139, 58, 58, 0.12);
  margin-bottom: 40rpx;
}

.logo {
  width: 100%;
  height: 100%;
  display: block;
}

.title {
  font-size: 44rpx;
  font-weight: 900;
  color: #2D2D2D;
  margin-bottom: 16rpx;
}

.subtitle {
  font-size: 28rpx;
  color: #8D6E63;
}

.login-box {
  width: 100%;
  display: flex;
  flex-direction: column;
  gap: 40rpx;
  margin-bottom: 60rpx;
}

.login-tip {
  text-align: center;
  font-size: 24rpx;
  color: #8D6E63;
  line-height: 1.7;
}

.btn-wechat {
  width: 100% !important;
  height: 96rpx;
  border-radius: 48rpx;
  background-color: #07C160;
  color: white;
  font-size: 32rpx;
  font-weight: 600;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 0;
  box-shadow: 0 8rpx 20rpx rgba(7, 193, 96, 0.3);
}

.btn-wechat .icon {
  margin-right: 12rpx;
}

.divider {
  display: flex;
  align-items: center;
  width: 100%;
}

.divider .line {
  flex: 1;
  height: 1rpx;
  background-color: #E8D5C8;
}

.divider .text {
  padding: 0 30rpx;
  font-size: 24rpx;
  color: #A1887F;
}

.btn-mock {
  width: 100% !important;
  height: 96rpx;
  border-radius: 48rpx;
  background-color: #fff;
  color: #2D2D2D;
  font-size: 32rpx;
  font-weight: 600;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 0;
  border: 2rpx solid #E8D5C8;
}

.agreement {
  margin-top: auto;
  padding-top: 60rpx;
  width: 100%;
  text-align: center;
}

.checkbox-label {
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 24rpx;
}

.checkbox-label .text {
  color: #8D6E63;
}

.checkbox-label .link {
  color: #2D2D2D;
  font-weight: 600;
}
